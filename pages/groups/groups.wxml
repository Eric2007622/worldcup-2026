<!--pages/groups/groups.wxml-->
<view class="container">
  <view class="section-title">📊 小组积分榜</view>

  <!-- 小组选择 -->
  <scroll-view scroll-x class="group-scroll">
    <view wx:for="{{groupKeys}}" wx:key="*this" class="group-chip {{selectedGroup === item ? 'active' : ''}}" bindtap="selectGroup" data-group="{{item}}">
      {{item}}组
    </view>
  </scroll-view>

  <!-- 积分榜 -->
  <view wx:for="{{groups}}" wx:key="key">
    <view wx:if="{{item.key === selectedGroup}}" class="group-card">
      <view class="group-title">{{item.name}}</view>

      <!-- 表头 -->
      <view class="standing-header">
        <text class="col-rank">#</text>
        <text class="col-team">球队</text>
        <text class="col-stat">赛</text>
        <text class="col-stat">胜</text>
        <text class="col-stat">平</text>
        <text class="col-stat">负</text>
        <text class="col-stat">进</text>
        <text class="col-stat">失</text>
        <text class="col-stat">净</text>
        <text class="col-pts">分</text>
      </view>

      <!-- 球队行 -->
      <view wx:for="{{item.teams}}" wx:for-item="team" wx:key="name" class="standing-row">
        <text class="col-rank">{{team.rank}}</text>
        <view class="col-team">
          <text class="team-flag-small">{{team.flag}}</text>
          <text class="team-name-small">{{team.name}}</text>
        </view>
        <text class="col-stat">{{team.mp}}</text>
        <text class="col-stat">{{team.w}}</text>
        <text class="col-stat">{{team.d}}</text>
        <text class="col-stat">{{team.l}}</text>
        <text class="col-stat">{{team.gf}}</text>
        <text class="col-stat">{{team.ga}}</text>
        <text class="col-stat" style="color: {{team.gd > 0 ? '#4caf50' : team.gd < 0 ? '#f44336' : '#5a6580'}}">{{team.gdStr}}</text>
        <text class="col-pts pts">{{team.pts}}</text>
      </view>

      <!-- 出线说明 -->
      <view class="group-note">
        <text>前2名直接晋级 · 8个最佳第三名晋级</text>
      </view>
    </view>
  </view>

  <!-- 出线规则 -->
  <view class="card" style="margin-top: 30rpx;">
    <view style="font-size: 28rpx; font-weight: 700; color: #ffd700; margin-bottom: 16rpx;">📌 出线规则</view>
    <view style="font-size: 24rpx; color: #8892b0; line-height: 1.8;">
      • 48队分为12组，每组4队\n
      • 每组前2名直接晋级（24队）\n
      • 8个最佳小组第三名晋级（8队）\n
      • 共32队进入淘汰赛\n
      • 同分先看净胜球，再看进球数
    </view>
  </view>
</view>
