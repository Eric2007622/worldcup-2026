/* pages/schedule/schedule.wxss */
.date-scroll {
  white-space: nowrap;
  padding: 10rpx 0;
}
.date-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #141929;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #5a6580;
  border: 2rpx solid #1e2640;
}
.date-chip.active {
  background: #1a2a4a;
  color: #ffd700;
  border-color: #ffd700;
}
