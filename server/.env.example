# 世界杯小程序环境配置

# 数据模式: cloud | server | static
# cloud  = 微信云函数 (推荐，需要开通云开发)
# server = 自建后端服务
# static = 本地静态数据 (离线可用)

DATA_MODE=static

# ===== football-data.org (免费) =====
# 注册: https://www.football-data.org/client/register
FD_API_KEY=your_api_key_here

# ===== sports.bzzoiro.com (免费，可选) =====
# 注册: https://sports.bzzoiro.com/register/
BSD_API_KEY=

# ===== 后端服务配置 =====
PORT=3000
